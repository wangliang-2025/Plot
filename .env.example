# ─────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────
# Replace with your Neon/Supabase/RDS/Postgres connection string.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ink_blog?schema=public"

# ─────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# Generate AUTH_SECRET with: openssl rand -base64 32
# or:  npx auth secret
# ─────────────────────────────────────────────────────
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_TRUST_HOST=true

# ─────────────────────────────────────────────────────
# Initial admin (used by `npm run db:seed`)
# ─────────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin"

# ─────────────────────────────────────────────────────
# 本地开发：启动时浏览器自动用 admin 凭据登录
#   1 / 不设置 → 启用（默认）；浏览器打开 /zh?autologin=1 触发
#   0          → 关闭，启动后保持未登录
# 仅在 NODE_ENV=development 生效；生产环境一律 403。
# ─────────────────────────────────────────────────────
DEV_AUTOLOGIN="1"

# ─────────────────────────────────────────────────────
# Public site config
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Ink"
NEXT_PUBLIC_SITE_DESCRIPTION="A modern personal blog"
NEXT_PUBLIC_SITE_AUTHOR="Your Name"

# ─────────────────────────────────────────────────────
# Gitee 个人主页 (/me)
# 必填：你的 Gitee 用户名（gitee.com/<username>）
# 选填：Personal access token，可提高 API 速率上限到 5000/h
#       https://gitee.com/profile/personal_access_tokens
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_GITEE_USERNAME=""
GITEE_ACCESS_TOKEN=""
